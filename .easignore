# Keep this section in sync with .gitignore. EAS uses this file instead of
# .gitignore when it exists.

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native projects are generated by Expo Prebuild on EAS.
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.aab
*.apk
/ios
/android

# Metro
.metro-health-check*

# Local screenshot automation
.artifacts/

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# TypeScript
*.tsbuildinfo

example

# EAS Build does not need product documentation, the marketing website, or
# local screenshot automation.
/docs/
/website/
/.maestro/
/scripts/screenshots.mjs

# Local editor and coding-agent configuration
/.claude/
/.cursor/
/.vscode/
/AGENTS.md
/CLAUDE.md

# Tests and local-only quality tooling
**/__tests__/
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
/vitest.config.ts
/.prettierignore
/.prettierrc
/eslint.config.js
