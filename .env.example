# Copy this file to `.env` and fill in the values you need.
# All EXPO_PUBLIC_* vars are embedded in the client bundle — never put secrets here.

# Public marketing site URL used for in-app links (optional).
EXPO_PUBLIC_SITE_URL=https://tryowed.vercel.app

# Optional: backend for the in-app "Share feedback" form.
# Leave blank to disable feedback submission. Use your own Supabase project.
EXPO_PUBLIC_FEEDBACK_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_FEEDBACK_SUPABASE_PUBLISHABLE_KEY=
