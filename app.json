{
  "expo": {
    "name": "Owwed",
    "slug": "owed",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "owed",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.vincentmukuna.owed",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "blockedPermissions": [
        "android.permission.WRITE_CONTACTS",
        "android.permission.READ_MEDIA_IMAGES"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#1A3A2A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.vincentmukuna.owed"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "./plugins/with-android-release-build-memory",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1A3A2A",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 120
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#1A3A2A"
        }
      ],
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      "expo-localization",
      "expo-sharing",
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow Owwed to access your contacts so you can quickly choose a phone number."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Owwed to use Face ID to unlock the app."
        }
      ],
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true,
          "faceIDPermission": "Allow Owwed to use Face ID to unlock the app."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d410a7a9-330d-4a31-be09-dcb768a1befa"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/d410a7a9-330d-4a31-be09-dcb768a1befa"
    }
  }
}
